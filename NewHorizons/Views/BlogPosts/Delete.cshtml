@model NewHorizons.Models.BlogPost

@{
    ViewData["Title"] = "Delete Article";
}

<div class="article-details-page">

    ```
    <div class="article-container">

        <h1 class="article-title">Delete Article</h1>

        <p class="text-danger"><strong>Are you sure you want to delete this article?</strong></p>

        <hr />

        <div class="article-body">

            <p><strong>Title:</strong> @Model.Title</p>

            <p><strong>Created:</strong> @Model.CreatedAt</p>

            <p><strong>Public:</strong> @Model.IsPublic</p>

            <p><strong>Comments Enabled:</strong> @Model.CommentsEnabled</p>

            <p><strong>Author:</strong> @Model.Author?.Id</p>

        </div>

        <form asp-action="Delete">

            <input type="hidden" asp-for="PostId" />

            <div class="article-actions">
                <input type="submit" value="Delete" class="btn btn-danger" />
                <a asp-action="Index" class="btn-back">Cancel</a>
            </div>

        </form>

    </div>

</div>
