@model NewHorizons.Models.BlogPost

@{
    ViewData["Title"] = "Edit Article";
}

<div class="article-details-page">

    ```
    <div class="article-container">

        <h1 class="article-title">Edit Article</h1>
        <hr />

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="PostId" />

            <div class="form-group mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="BodyHtml" class="form-label"></label>
                <textarea asp-for="BodyHtml" class="form-control" rows="10"></textarea>
                <span asp-validation-for="BodyHtml" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CreatedAt" class="form-label"></label>
                <input asp-for="CreatedAt" class="form-control" />
                <span asp-validation-for="CreatedAt" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="IsPublic" />
                <label class="form-check-label">@Html.DisplayNameFor(model => model.IsPublic)</label>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="CommentsEnabled" />
                <label class="form-check-label">@Html.DisplayNameFor(model => model.CommentsEnabled)</label>
            </div>

            <div class="form-group mb-4">
                <label asp-for="AuthorId" class="form-label"></label>
                <select asp-for="AuthorId" class="form-control" asp-items="ViewBag.AuthorId"></select>
                <span asp-validation-for="AuthorId" class="text-danger"></span>
            </div>

            <div class="article-actions">
                <input type="submit" value="Save Changes" class="btn-back" />
                <a asp-action="Index" class="btn-back">Back to Articles</a>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
