@model IEnumerable<NewHorizons.Models.BlogPost>

@{
    ViewData["Title"] = "Approval Queue";
}

<h1>Moderation Queue</h1>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Author.Id</td>
                <td>@item.CreatedAt.ToShortDateString()</td>
                <td>
                    <form asp-action="Approve" asp-route-id="@item.PostId" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-primary">Approve</button>
                    </form> |
                    <a asp-action="Details" asp-route-id="@item.PostId">Review</a> |
                    <a asp-action="Delete" asp-route-id="@item.PostId">Reject</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index">Back to Blog</a>