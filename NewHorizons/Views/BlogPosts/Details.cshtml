@model NewHorizons.Models.BlogPost

@{
    ViewData["Title"] = "Details";
}

<div class="article-details-page">

    ```
    <div class="article-container">

        <h1 class="article-title">@Model.Title</h1>

        <div class="article-meta">
            Posted by @Model.Author?.Id • @Model.CreatedAt.ToString("MMMM dd, yyyy")
        </div>

        <hr />

        <div class="article-body">
            @Html.Raw(Model.BodyHtml)
        </div>

        <hr />

        <div class="article-info">

            <p><strong>Public:</strong> @Model.IsPublic</p>

            <p><strong>Comments Enabled:</strong> @Model.CommentsEnabled</p>

        </div>

        <div class="article-actions">
            <a asp-action="Edit" asp-route-id="@Model?.PostId" class="btn-back">Edit</a>
            <a asp-action="Index" class="btn-back">Back to List</a>
        </div>

    </div>
    ```

</div>
