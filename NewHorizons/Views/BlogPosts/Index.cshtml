@model IEnumerable<NewHorizons.Models.BlogPost>

@{
    ViewData["Title"] = "Articles";
}

<div class="articles-page">

    <div class="articles-header">
        Click an article to read further and leave a comment!
    </div>

    <div class="articles-container">

        @foreach (var item in Model)
        {
            <a class="article-card" asp-action="Details" asp-route-id="@item.PostId">

                <div class="article-image">
                    <img src="~/images/article-placeholder.jpg" alt="Article Image" />
                </div>

                <div class="article-content">
                    <h3>@item.Title</h3>

                    <p>
                        @(item.BodyHtml.Length > 150
                            ? item.BodyHtml.Substring(0, 150) + "..."
                            : item.BodyHtml)
                </p>
            </div>

            </a>
                }

    </div>

    <div class="write-article">
        <a class="btn-write" asp-action="Create">Write An Article</a>
    </div>

</div>