@model IEnumerable<NewHorizons.Models.ApplicationUser>

@{
    ViewData["Title"] = "User Management";
    var userRoles = ViewBag.UserRoles as Dictionary<string, bool>;
}

<h1>User Management</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Email</th>
            <th>Display Name</th>
            <th>Email Confirmed</th>
            <th>Admin</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.DisplayName</td>
                <td>@user.EmailConfirmed</td>
                <td>@(userRoles != null && userRoles.ContainsKey(user.Id) && userRoles[user.Id] ? "Yes" : "No")</td>
                <td>
                    <a asp-area="Admin"
                       asp-controller="Users"
                       asp-action="Details"
                       asp-route-id="@user.Id"
                       class="btn btn-sm btn-primary">
                        Details
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>