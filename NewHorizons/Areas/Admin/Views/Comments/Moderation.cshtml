@model IEnumerable<NewHorizons.Models.Comment>

<h2>Comment Moderation</h2>

<table class="table">
    <thead>
        <tr>
            <th>Author</th>
            <th>Post</th>
            <th>Comment</th>
            <th>Date</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var comment in Model)
        {
            <tr>
                <td>@comment.Author?.DisplayName</td>
                <td>@comment.Post?.Title</td>
                <td>@comment.Body</td>
                <td>@comment.CreatedAt</td>

                <td>
                    <a asp-action="ToggleHidden"
                       asp-route-id="@comment.CommentId"
                       class="btn btn-warning btn-sm">
                        Hide
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@comment.CommentId"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }

    </tbody>
</table>